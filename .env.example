APP_ENV=production
APP_NAME=SmartStock
APP_BASE_URL=https://your-public-url.example

DB_HOST=127.0.0.1
DB_USER=root
DB_PASS=
DB_NAME=products_ordering_db
DB_PORT=3306

MAIL_TRANSPORT=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your-brevo-smtp-login
MAIL_PASSWORD=your-brevo-smtp-key
MAIL_ENCRYPTION=tls
MAIL_FROM_EMAIL=your-verified-sender@example.com
MAIL_FROM_NAME=SmartStock
MAIL_TIMEOUT=15

SSLCOMMERZ_ENABLED=1
SSLCOMMERZ_SANDBOX=1
SSLCOMMERZ_STORE_ID=your-sandbox-store-id
SSLCOMMERZ_STORE_PASSWORD=your-sandbox-store-password
SSLCOMMERZ_CURRENCY=BDT
SSLCOMMERZ_SESSION_API=https://sandbox.sslcommerz.com/gwprocess/v4/api.php
SSLCOMMERZ_VALIDATION_API=https://sandbox.sslcommerz.com/validator/api/validationserverAPI.php
